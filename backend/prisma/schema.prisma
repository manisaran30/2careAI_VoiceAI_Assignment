generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  timings   String?  @db.Text
  services  String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors     Doctor[]
  appointments Appointment[]

  @@map("branches")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors Doctor[]

  @@map("departments")
}

model Doctor {
  id              String   @id @default(cuid())
  name            String
  specialty       String
  experience      Int?
  consultationFee Float?
  languages       String  @db.Text
  availableDays   String  @db.Text
  qualifications  String  @db.Text
  profileImage    String? @db.Text
  bio             String? @db.Text
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments    Appointment[]
  appointmentSlots AppointmentSlot[]

  @@index([specialty])
  @@index([branchId])
  @@index([departmentId])
  @@map("doctors")
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments     Appointment[]
  callLogs         CallLog[]
  humanFollowups   HumanFollowup[]
  conversationSummaries ConversationSummary[]

  @@map("patients")
}

model Appointment {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  date       DateTime
  time       String
  status     String   @default("scheduled")
  reason     String? @db.Text
  notes      String? @db.Text
  source     String   @default("manual")
  callLogId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  callLog CallLog? @relation(fields: [callLogId], references: [id])

  @@index([patientId])
  @@index([doctorId, date])
  @@index([date])
  @@map("appointments")
}

model CallLog {
  id             String   @id @default(cuid())
  callId         String   @unique
  sessionId      String?
  phone          String
  direction      String   @default("inbound")
  status         String   @default("completed")
  duration       Int?
  intent         String?
  summary        String? @db.Text
  operation      String?
  transcript     String? @db.Text
  partialSession Boolean  @default(false)
  errorLog       String? @db.Text
  patientId      String?
  patient        Patient? @relation(fields: [patientId], references: [id])
  metadata       String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments        Appointment[]
  conversationSummary ConversationSummary?
  humanFollowups      HumanFollowup[]
  webhookEvents       WebhookEvent[]
  callEvents          CallEvent[]

  @@index([sessionId])
  @@index([phone])
  @@index([createdAt])
  @@map("call_logs")
}

model CallEvent {
  id        String   @id @default(cuid())
  sessionId String
  callLogId String?
  callLog   CallLog? @relation(fields: [callLogId], references: [id])
  eventType String
  payload   String   @db.Text
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@map("call_events")
}

model ConversationSummary {
  id             String   @id @default(cuid())
  callLogId      String   @unique
  callLog        CallLog  @relation(fields: [callLogId], references: [id])
  patientId      String?
  patient        Patient? @relation(fields: [patientId], references: [id])
  patientName    String? @db.Text
  intent         String? @db.Text
  doctor         String? @db.Text
  department     String? @db.Text
  branch         String? @db.Text
  appointmentTime String? @db.Text
  outcome        String? @db.Text
  callDuration   Int?
  summary        String? @db.Text
  createdAt      DateTime @default(now())

  @@map("conversation_summaries")
}

model HumanFollowup {
  id        String   @id @default(cuid())
  callLogId String?
  callLog   CallLog? @relation(fields: [callLogId], references: [id])
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  reason    String
  notes     String? @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("human_followups")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  callLogId String?
  callLog   CallLog? @relation(fields: [callLogId], references: [id])
  eventType String
  payload   String? @db.Text
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([eventType])
  @@map("webhook_events")
}

model AppointmentSlot {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  date      DateTime
  time      String
  status    String   @default("available")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId, date, status])
  @@index([doctorId, date, time])
  @@map("appointment_slots")
}

model EvaluationResult {
  id            String   @id @default(cuid())
  scenario      String
  passed        Boolean
  executionTime Int?
  outcome       String? @db.Text
  details       String? @db.Text
  createdAt     DateTime @default(now())

  @@map("evaluation_results")
}
