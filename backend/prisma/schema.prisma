generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  timings   String?  @db.Text  // JSON: {"weekday": "08:00-20:00", "weekend": "09:00-17:00"}
  services  String   @db.Text  // JSON array stringified
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors     Doctor[]
  appointments Appointment[]

  @@map("branches")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors Doctor[]

  @@map("departments")
}

model Doctor {
  id              String   @id @default(cuid())
  name            String
  specialty       String
  experience      Int?
  consultationFee Float?
  languages       String  @db.Text  // JSON array stringified: ["English","Tamil"]
  availableDays   String  @db.Text  // JSON array stringified: ["Monday","Tuesday"]
  qualifications  String  @db.Text  // JSON array stringified
  profileImage    String? @db.Text
  bio             String? @db.Text
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments    Appointment[]
  appointmentSlots AppointmentSlot[]

  @@index([specialty])
  @@index([branchId])
  @@index([departmentId])
  @@map("doctors")
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments     Appointment[]
  callLogs         CallLog[]
  humanFollowups   HumanFollowup[]
  conversationSummaries ConversationSummary[]

  @@map("patients")
}

model Appointment {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  date       DateTime
  time       String   // "10:30"
  status     String   @default("scheduled") // scheduled, completed, cancelled, rescheduled, no_show
  reason     String? @db.Text
  notes      String? @db.Text
  source     String   @default("manual") // manual, ai, phone
  callLogId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  callLog CallLog? @relation(fields: [callLogId], references: [id])

  @@index([patientId])
  @@index([doctorId, date])
  @@index([date])
  @@map("appointments")
}

model CallLog {
  id             String   @id @default(cuid())
  callId         String   @unique // Bolna call ID
  sessionId      String?  // Unique session identifier for frontend tracking
  phone          String
  direction      String   @default("inbound")
  status         String   @default("completed") // connecting, active, processing, completed, failed, missed, incomplete
  duration       Int?     // seconds
  intent         String?
  summary        String? @db.Text
  operation      String?  // Current operation: "checking_doctor", "booking", etc.
  transcript     String? @db.Text // Accumulated transcript JSON stringified
  partialSession Boolean  @default(false) // true if call disconnected unexpectedly
  errorLog       String? @db.Text // JSON array of errors
  patientId      String?
  patient        Patient? @relation(fields: [patientId], references: [id])
  metadata       String? @db.Text // JSON string
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments        Appointment[]
  conversationSummary ConversationSummary?
  humanFollowups      HumanFollowup[]
  webhookEvents       WebhookEvent[]
  callEvents          CallEvent[]

  @@index([sessionId])
  @@index([phone])
  @@index([createdAt])
  @@map("call_logs")
}

model CallEvent {
  id        String   @id @default(cuid())
  sessionId String
  callLogId String?
  callLog   CallLog? @relation(fields: [callLogId], references: [id])
  eventType String   // status_update, transcript, operation, error, summary
  payload   String   @db.Text // JSON
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@map("call_events")
}

model ConversationSummary {
  id             String   @id @default(cuid())
  callLogId      String   @unique
  callLog        CallLog  @relation(fields: [callLogId], references: [id])
  patientId      String?
  patient        Patient? @relation(fields: [patientId], references: [id])
  patientName    String? @db.Text
  intent         String? @db.Text
  doctor         String? @db.Text
  department     String? @db.Text
  branch         String? @db.Text
  appointmentTime String? @db.Text
  outcome        String? @db.Text // booked, rescheduled, cancelled, handoff, faq, incomplete
  callDuration   Int?
  summary        String? @db.Text
  createdAt      DateTime @default(now())

  @@map("conversation_summaries")
}

model HospitalInfo {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text // JSON

  @@map("hospital_info")
}

model HumanFollowup {
  id        String   @id @default(cuid())
  callLogId String?
  callLog   CallLog? @relation(fields: [callLogId], references: [id])
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  reason    String
  notes     String? @db.Text
  status    String   @default("pending") // pending, contacted, resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("human_followups")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  callLogId String?
  callLog   CallLog? @relation(fields: [callLogId], references: [id])
  eventType String   // call_started, call_completed, booking
  payload   String? @db.Text // JSON string
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([eventType])
  @@map("webhook_events")
}

model AppointmentSlot {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  date      DateTime
  time      String   // "10:00"
  status    String   @default("available") // available, booked, blocked
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId, date, status])
  @@index([doctorId, date, time])
  @@map("appointment_slots")
}

model EvaluationResult {
  id            String   @id @default(cuid())
  scenario      String
  passed        Boolean
  executionTime Int?     // ms
  outcome       String? @db.Text
  details       String? @db.Text // JSON string
  createdAt     DateTime @default(now())

  @@map("evaluation_results")
}
